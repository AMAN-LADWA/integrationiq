# Tenant anonymisation — set to false on org machines to show real names
TENANT_ANONYMISE=true

# InfluxDB (external, already running)
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=your-influxdb-token
INFLUX_ORG=your-org
INFLUX_BUCKET=cpi

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# PostgreSQL (managed by docker-compose)
POSTGRES_USER=iiq
POSTGRES_PASSWORD=iiq_secret
